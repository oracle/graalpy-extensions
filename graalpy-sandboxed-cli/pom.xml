<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.graalvm.python</groupId>
        <artifactId>graalpy-extensions</artifactId>
        <version>${revision}</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>graalpy-sandboxed-cli</artifactId>
    <version>${revision}</version>

    <properties>
        <!-- used to switch integration tests between jar and native-image mode -->
        <packaging>jar</packaging>
        <exec.mainClass>org.graalvm.python.sandboxed.cli.GraalPySandboxedCli</exec.mainClass>
        <native.maven.plugin.version>0.10.4</native.maven.plugin.version>
        <!-- Resolved via OS/arch-activated profiles below -->
        <python.isolate.artifactId>python-isolate-linux-amd64</python.isolate.artifactId>
        <project.polyglot.version>25.0.2</project.polyglot.version>
    </properties>

    <profiles>
        <profile>
            <id>python-isolate-linux-amd64</id>
            <activation>
                <os>
                    <family>linux</family>
                    <arch>amd64</arch>
                </os>
            </activation>
            <properties>
                <python.isolate.artifactId>python-isolate-linux-amd64</python.isolate.artifactId>
            </properties>
        </profile>
        <profile>
            <id>python-isolate-linux-aarch64</id>
            <activation>
                <os>
                    <family>linux</family>
                    <arch>aarch64</arch>
                </os>
            </activation>
            <properties>
                <python.isolate.artifactId>python-isolate-linux-aarch64</python.isolate.artifactId>
            </properties>
        </profile>
        <profile>
            <id>python-isolate-macos-amd64</id>
            <activation>
                <os>
                    <family>mac</family>
                    <arch>x86_64</arch>
                </os>
            </activation>
            <properties>
                <python.isolate.artifactId>python-isolate-darwin-amd64</python.isolate.artifactId>
            </properties>
        </profile>
        <profile>
            <id>python-isolate-macos-aarch64</id>
            <activation>
                <os>
                    <family>mac</family>
                    <arch>aarch64</arch>
                </os>
            </activation>
            <properties>
                <python.isolate.artifactId>python-isolate-darwin-aarch64</python.isolate.artifactId>
            </properties>
        </profile>
        <profile>
            <id>python-isolate-windows-amd64</id>
            <activation>
                <os>
                    <family>windows</family>
                    <arch>amd64</arch>
                </os>
            </activation>
            <properties>
                <python.isolate.artifactId>python-isolate-windows-amd64</python.isolate.artifactId>
            </properties>
        </profile>
        <profile>
            <id>native-image</id>
            <activation>
                <property>
                    <name>packaging</name>
                    <value>native-image</value>
                </property>
            </activation>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.graalvm.buildtools</groupId>
                        <artifactId>native-maven-plugin</artifactId>
                        <version>${native.maven.plugin.version}</version>
                        <executions>
                            <execution>
                                <id>build-native-image</id>
                                <phase>package</phase>
                                <goals>
                                    <goal>compile-no-fork</goal>
                                </goals>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>

    <dependencies>
        <dependency>
            <groupId>org.graalvm.polyglot</groupId>
            <artifactId>polyglot</artifactId>
            <scope>compile</scope>
        </dependency>
        <dependency>
            <groupId>org.graalvm.python</groupId>
            <artifactId>python</artifactId>
            <type>pom</type>
            <version>${project.polyglot.version}</version>
            <scope>compile</scope>
        </dependency>
        <dependency>
            <groupId>org.graalvm.python</groupId>
            <artifactId>${python.isolate.artifactId}</artifactId>
            <version>${project.polyglot.version}</version>
            <scope>compile</scope>
        </dependency>
        <dependency>
            <groupId>org.graalvm.truffle</groupId>
            <artifactId>truffle-enterprise</artifactId>
            <version>${project.polyglot.version}</version>
            <scope>runtime</scope>
        </dependency>

        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-enforcer-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <configuration>
                    <archive>
                        <manifest>
                            <mainClass>${exec.mainClass}</mainClass>
                        </manifest>
                    </archive>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.graalvm.buildtools</groupId>
                <artifactId>native-maven-plugin</artifactId>
                <version>${native.maven.plugin.version}</version>
                <configuration>
                    <imageName>graalpy-sandboxed</imageName>
                    <mainClass>${exec.mainClass}</mainClass>
                    <buildArgs>
                        <buildArg>-Dpython.WithoutNativePosix=true</buildArg>
                        <buildArg>-Dpython.WithoutJavaInet=true</buildArg>
                    </buildArgs>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-failsafe-plugin</artifactId>
                <version>3.5.4</version>
                <executions>
                    <execution>
                        <goals>
                            <goal>integration-test</goal>
                            <goal>verify</goal>
                        </goals>
                        <configuration>
                            <systemPropertyVariables>
                                <test.packaging>${packaging}</test.packaging>
                                <test.buildDir>${project.build.directory}</test.buildDir>
                                <test.finalName>${project.build.finalName}</test.finalName>
                                <test.javaCmd>${java.home}/bin/java</test.javaCmd>
                            </systemPropertyVariables>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
